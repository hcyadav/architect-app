generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  user
  admin
}

model User {
  id        String      @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String      @unique
  image     String?
  role      Role        @default(user)
  quotations Quotation[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

enum Category {
  product
  corporate
  premium
}

type CustomField {
  label String
  value String
}

model Product {
  id               String      @id @default(auto()) @map("_id") @db.ObjectId
  title            String
  description      String
  category         Category
  subCategory      String?
  imageUrl         String
  additionalImages String[]
  price            String?
  companyName      String?
  isBestProduct    Boolean     @default(false)
  customFields     CustomField[]
  quotations       Quotation[]
  portfolios       Portfolio[]
  testimonials     Testimonial[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

enum QuotationStatus {
  pending
  reviewed
  accepted
}

model Quotation {
  id        String          @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?         @db.ObjectId
  user      User?           @relation(fields: [userId], references: [id])
  name      String?
  email     String?
  productId String?         @db.ObjectId
  product   Product?        @relation(fields: [productId], references: [id])
  message   String
  status    QuotationStatus @default(pending)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

type QuotationItem {
  description String
  rate        Float
  quantity    Int
  amount      Float
}

model OfficialQuotation {
  id          String          @id @default(auto()) @map("_id") @db.ObjectId
  clientName  String
  clientEmail String?
  items       QuotationItem[]
  totalAmount Float
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

enum EmployeeStatus {
  active
  inactive
}

model Employee {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  firstName   String
  lastName    String
  phoneNumber String
  designation String
  joiningDate DateTime       @default(now())
  status      EmployeeStatus @default(active)
  attendance  Attendance[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

enum AttendanceStatus {
  full
  half
  holiday
  hourly
  absent
  full_day
  half_day
  one_five_days @map("1.5_days")
  two_days      @map("2_days")
}

model Attendance {
  id         String           @id @default(auto()) @map("_id") @db.ObjectId
  employeeId String           @db.ObjectId
  employee   Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date       DateTime
  status     AttendanceStatus
  hours      Float?
  remarks    String?
  wages      Float?           @default(0)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([employeeId, date])
}

model Portfolio {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  title            String
  description      String
  imageUrl         String
  additionalImages String[]
  location         String?
  completionDate   String?
  clientName       String?
  productId        String?  @db.ObjectId
  product          Product? @relation(fields: [productId], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Settings {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Testimonial {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  clientName String
  role       String?
  company    String?
  content    String
  rating     Int      @default(5)
  imageUrl   String?
  productId  String?  @db.ObjectId
  product    Product? @relation(fields: [productId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
